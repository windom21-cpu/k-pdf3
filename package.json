{
  "name": "k-pdf3",
  "version": "2.0.0-beta.149",
  "description": "法律実務向け PDF Workspace（K-PDF2 の全面再設計版）",
  "private": true,
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start": "electron . --no-sandbox --ozone-platform-hint=x11",
    "dev": "electronmon . --no-sandbox --ozone-platform-hint=x11",
    "spike": "node spike/mupdf-layout.mjs",
    "test:coord": "node test/coord.test.mjs",
    "test:m1": "electron --no-sandbox test/electron-runner.cjs",
    "test:render": "node test/render.test.mjs",
    "test:render-service": "node test/render-service.test.mjs",
    "test:rotation-overlay": "node --test test/rotation-overlay.test.mjs",
    "test:page-registry": "node test/page-registry.test.mjs",
    "test:project-store": "node test/project-store.test.mjs",
    "test:history": "node test/history.test.mjs",
    "test:sidecar-sweep": "node test/sidecar-sweep.test.mjs",
    "test": "npm run test:coord && npm run test:page-registry && npm run test:project-store && npm run test:history && npm run test:sidecar-sweep && npm run test:m1 && npm run test:render && npm run test:render-service && npm run test:rotation-overlay",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "build:icon": "node scripts/build-icon.mjs",
    "prebuild": "npm run build:icon",
    "prebuild:linux": "npm run build:icon",
    "prebuild:win": "npm run build:icon",
    "prebuild:mac": "npm run build:icon",
    "build": "electron-builder --publish=never",
    "build:linux": "electron-builder --linux --publish=never",
    "build:win": "electron-builder --win --publish=never",
    "build:mac": "electron-builder --mac --publish=never",
    "publish:linux": "npm run build:icon && electron-builder --linux --publish=always",
    "publish:win": "npm run build:icon && electron-builder --win --publish=always",
    "publish:mac": "npm run build:icon && electron-builder --mac --publish=always"
  },
  "author": {
    "name": "windom21-cpu",
    "email": "279377893+windom21-cpu@users.noreply.github.com"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.22.2"
  },
  "devDependencies": {
    "electron": "41.7.1",
    "electron-builder": "26.8.1",
    "electronmon": "^2.0.4"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "electron-updater": "6.8.5",
    "koffi": "2.16.2",
    "mupdf": "^1.27.0",
    "pdf-lib": "^1.17.1"
  },
  "build": {
    "appId": "io.windom21.kpdf3",
    "productName": "K-PDF3",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "windom21-cpu",
        "repo": "k-pdf3-releases",
        "releaseType": "prerelease"
      }
    ],
    "files": [
      "src/**/*",
      "schema/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts,*.map}",
      "!**/.{idea,git,github}",
      "!test/**/*",
      "!spike/**/*",
      "!docs/**/*",
      "!HANDOVER.md",
      "!ROADMAP.md"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/build/**",
      "node_modules/mupdf/dist/**"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "synopsis": "PDF Workspace for legal practice",
      "description": "法律実務向けの PDF Workspace アプリ（K-PDF2 の全面再設計版）",
      "extraResources": [
        {
          "from": "vendor/qpdf/linux",
          "to": "qpdf"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "vendor/sumatrapdf/SumatraPDF.exe",
          "to": "sumatrapdf/SumatraPDF.exe"
        },
        {
          "from": "vendor/sumatrapdf/COPYING",
          "to": "sumatrapdf/COPYING.txt"
        },
        {
          "from": "vendor/qpdf/win",
          "to": "qpdf"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "extraResources": [
        {
          "from": "vendor/qpdf/mac",
          "to": "qpdf"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
