{
  "name": "k-pdf3",
  "version": "2.0.0",
  "description": "法律実務向け PDF Workspace（K-PDF2 の全面再設計版）",
  "private": true,
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electronmon . --no-sandbox",
    "spike": "node spike/mupdf-layout.mjs",
    "test:coord": "node test/coord.test.mjs",
    "test:m1": "electron --no-sandbox test/electron-runner.cjs",
    "test:render": "node test/render.test.mjs",
    "test:render-service": "node test/render-service.test.mjs",
    "test:page-registry": "node test/page-registry.test.mjs",
    "test:project-store": "node test/project-store.test.mjs",
    "test": "npm run test:coord && npm run test:page-registry && npm run test:project-store && npm run test:m1 && npm run test:render && npm run test:render-service",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "author": {
    "name": "windom21-cpu",
    "email": "279377893+windom21-cpu@users.noreply.github.com"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.22.2"
  },
  "devDependencies": {
    "electron": "^38.8.6",
    "electron-builder": "26.8.1",
    "electronmon": "^2.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "mupdf": "^1.27.0"
  }
}
