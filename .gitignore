fonts/msgothic.ttc
fonts/MSUIGothic.ttf

# Environment
.env
.env.local

# SQLite WAL/SHM (per-workspace transient files)
*.kpdf3-wal
*.kpdf3-shm

# Spike artifacts
spike/output/
spike/*.pdf

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.Trash-*

# Claude Code per-project settings
.claude/
